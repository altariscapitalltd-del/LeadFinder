# AI provider keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# App/runtime
APP_URL=http://localhost:3000
APP_FROM_NAME=LeadForge
NEXTAUTH_SECRET=change-this-to-a-random-string-at-least-32-characters

# Primary local storage
DATABASE_PATH=./leadforge.db

# Durable hosted storage migration target
DATABASE_URL=

# Scraper rendering fallback
PLAYWRIGHT_RENDER=1

# Optional rotating proxies (comma separated)
SCRAPER_PROXIES=

# SMTP safety
SMTP_ALLOW_INVALID_TLS=0
