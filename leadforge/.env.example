# ─── COPY THIS FILE TO .env.local AND FILL IN YOUR VALUES ───────────────────

# ── AI PROVIDER (pick one or more) ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# ── DEFAULT AI PROVIDER ──────────────────────────────────────────────────────
# Options: anthropic | openai | groq
DEFAULT_AI_PROVIDER=anthropic
DEFAULT_AI_MODEL=claude-sonnet-4-20250514

# ── DATABASE ──────────────────────────────────────────────────────────────────
# SQLite file path (relative to project root). Created automatically.
DATABASE_PATH=./leadforge.db

# ── APP ───────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=change-this-to-a-random-string-32chars
APP_URL=http://localhost:3000
